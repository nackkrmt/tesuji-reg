# Data backend: "supabase" (real backend) or "mock" (localStorage, no backend)
NEXT_PUBLIC_DATA_BACKEND=supabase

# Supabase project (publishable / anon key is safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Admin passphrase — must match app_config.admin_secret in the database.
# NOTE: this is a NEXT_PUBLIC_ var, so it ends up in the browser bundle — it is a
# demo-grade gate, NOT real security. Use a strong value and rotate it for production.
NEXT_PUBLIC_ADMIN_PASSPHRASE=change-me-to-a-strong-passphrase
