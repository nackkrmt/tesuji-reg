# Data backend: "supabase" (real backend) or "mock" (localStorage, no backend)
NEXT_PUBLIC_DATA_BACKEND=supabase

# Supabase project (publishable / anon key is safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Admin access is granted per-account via the Supabase Auth admin role
# (account_roles.role = 'admin') — there is no admin passphrase. Grant an account
# admin in SQL: insert into account_roles(account_id, role) values ('<uid>','admin').

# Optional: default merchant QR for single-operator setups. Paste a static Thai
# QR / PromptPay payload (e.g. exported from KBank "K SHOP", starts with
# 00020101…). When set, new tournaments default to this receiver and the app
# injects the amount per registration. Leave blank to use the phone/national-id
# flow instead.
NEXT_PUBLIC_DEFAULT_MERCHANT_QR=
